# ============================================
# .gitignore — Land Advisors
# ============================================

# ----- Sistema operativo -----
# Windows
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/
*.cab
*.msi
*.msix
*.msm
*.msp
*.lnk

# macOS
.DS_Store
.AppleDouble
.LSOverride
Icon
._*
.DocumentRevisions-V100
.fseventsd
.Spotlight-V100
.TemporaryItems
.Trashes
.VolumeIcon.icns
.com.apple.timemachine.donotpresent

# Linux
*~
.fuse_hidden*
.Trash-*
.nfs*

# ----- Editores / IDEs -----
# VS Code
.vscode/
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json
.history/

# IntelliJ / JetBrains
.idea/
*.iml
*.iws
*.ipr
out/

# Sublime Text
*.sublime-project
*.sublime-workspace

# Vim / Emacs
*.swp
*.swo
*~
.vscode/
.project
.classpath

# ----- Logs -----
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# ----- Entornos y dependencias -----
# Node.js (por si se añade en el futuro)
node_modules/
jspm_packages/
.npm/
.yarn/
.pnp.*
.pnp.js
.npmrc

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
venv/
env/
ENV/
.venv/
.env

# ----- Variables de entorno -----
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
.env.*.local

# ----- Archivos temporales y builds -----
dist/
build/
out/
*.tgz
*.tar.gz
.cache/
.parcel-cache/
.next/
.nuxt/
.vuepress/dist

# ----- Imágenes y assets temporales -----
# (No se ignoran las imágenes del proyecto, solo las temporales)
*.tmp
*.temp
*.bak
*.swp
*.orig
*.rej

# ----- Archivos subidos / generados por el usuario -----
uploads/
tmp/
temp/

# ----- Cobertura y reportes de tests -----
coverage/
*.lcov
.nyc_output/

# ----- Misceláneos ----
.DS_Store
*.pid
*.seed
*.pid.lock
.eslintcache
.stylelintcache
